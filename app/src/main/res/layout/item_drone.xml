<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/droneId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GA-001"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/droneName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Survey Drone"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/droneLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mysore"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:weightSum="2">

            <TextView
                android:id="@+id/droneStatus"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Flying" />

            <TextView
                android:id="@+id/droneBatteryText"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="85%"
                android:gravity="end" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/droneBatteryProgress"
            style="Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:progress="85"
            android:max="100" />

        <TextView
            android:id="@+id/batteryStateLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Healthy"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
